---
import Blocks from "../Blocks.astro";
import ActionGroupBlock from "../ActionGroupBlock/ActionGroupBlock.astro";
const { block } = Astro.props;
---

<section class="section-block">
  <header class="section-block-header">
    <h2>{block.title}</h2>
  </header>

  <Blocks blocks={block.body} />

  <footer class="section-block-footer">
    <ActionGroupBlock block={block.actions} />
  </footer>
</section>

<style>
  .section-block {
    margin: 0px -1px -1px -1px;
    border: 1px solid #1b263b;
    padding-block: var(--step-3);
  }

  .section-block-header {
    margin-block-end: var(--step-1);
    padding-inline: var(--step-2);
  }

  .section-block-footer {
    margin-block-start: var(--step-1);
    padding-inline: var(--step-2);
  }
</style>
