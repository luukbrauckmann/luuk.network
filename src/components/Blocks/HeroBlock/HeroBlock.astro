---
const { title, description } = Astro.props;
---

<div class="hero-block">
    <h1>{title}</h1>
    <p>{description}</p>
</div>

<style>
    .hero-block {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-inline: var(--step-1);
        height: 90dvh;
        gap: 2rem;
        border: 1px solid #1B263B;
        margin: -1px;
        margin-block-start: calc(-2.5em - 3px);
    }
</style>
