---
import type { ComponentProps } from 'astro/types';
import { StructuredText as DatocmsStructuredText } from '@datocms/astro';

type Props = ComponentProps<typeof DatocmsStructuredText>;

const props = Astro.props;
---

<div class="structured-text">
  <DatocmsStructuredText {...props} />
</div>

<style>
  :global(.structured-text p) {
    margin-block: var(--spacing-md);
  }

  :global(.structured-text h2) {
    margin-block: var(--spacing-xl) var(--spacing-lg);
  }

  :global(.structured-text h3) {
    margin-block: var(--spacing-lg) var(--spacing-md);
  }

  :global(.structured-text *:first-child) {
    margin-block-start: 0;
  }

  :global(.structured-text *:last-child) {
    margin-block-end: 0;
  }
</style>
